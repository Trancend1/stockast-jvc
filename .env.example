# ─────────────────────────────────────────────────────────────────────
# Public (client-accessible) — safe to expose in browser bundle
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────
# Server-only — NEVER expose to client. No NEXT_PUBLIC_ prefix.
# ─────────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# BMKG public API — Phase 2+. Phase 1 uses FEATURE_MOCK_WEATHER=true.
BMKG_API_BASE_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca

# Vercel KV (rate limit, idempotency, AI cache) — auto-provisioned on Vercel.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Phase 1 demo only — remove before Phase 2
# ─────────────────────────────────────────────────────────────────────
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
DEMO_OUTLET_ID=00000000-0000-0000-0000-000000000010

# ─────────────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────────────
FEATURE_AUTH_REQUIRED=false
FEATURE_MOCK_WEATHER=true
FEATURE_AI_PARSE_ENABLED=true
FEATURE_PROMO_GENERATION=true
# Auto-seed 7 days of demo data after onboarding so Belanja Card has history.
# Set to false in production with real merchants.
FEATURE_DEMO_AUTOSEED=true
# Voice input via Web Speech API (id-ID). Default OFF — enable for demo only
# after dry-run shows reliable recognition. Relaxes Permissions-Policy to
# microphone=(self) when true; otherwise microphone is blocked.
FEATURE_VOICE_INPUT=false
# Internal UI Kit reference page. Keep false outside local/preview audits.
FEATURE_UI_KIT_PREVIEW=false

# ─────────────────────────────────────────────────────────────────────
# Operations
# ─────────────────────────────────────────────────────────────────────
CRON_SECRET=replace-with-32-char-random-string

# Phase 2+ — observability
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

NODE_ENV=development
