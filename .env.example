# ─────────────────────────────────────────────────────────────────────
# Public (client-accessible) — safe to expose in browser bundle
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────
# Server-only — NEVER expose to client. No NEXT_PUBLIC_ prefix.
# ─────────────────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Vercel KV (rate limit, AI cache) — auto-provisioned on Vercel. Leave blank for local dev (degrades gracefully).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Demo mode (required when FEATURE_AUTH_REQUIRED=false)
# ─────────────────────────────────────────────────────────────────────
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
DEMO_OUTLET_ID=00000000-0000-0000-0000-000000000010

# ─────────────────────────────────────────────────────────────────────
# Feature flags
# ─────────────────────────────────────────────────────────────────────
FEATURE_AUTH_REQUIRED=false
FEATURE_MOCK_WEATHER=true
FEATURE_AI_PARSE_ENABLED=true
FEATURE_PROMO_GENERATION=true
# Auto-seed 7 days of demo data after onboarding so Belanja Card has history.
# Default OFF — keeps dev environment clean and empty-DB.
# Set to true only for final demo dry-run / judging walkthrough.
FEATURE_DEMO_AUTOSEED=false
# Voice input via Web Speech API (id-ID). Default OFF — enable for demo only
# after dry-run shows reliable recognition. Relaxes Permissions-Policy to
# microphone=(self) when true; otherwise microphone is blocked.
FEATURE_VOICE_INPUT=false
# Internal UI Kit reference page. Keep false outside local/preview audits.
FEATURE_UI_KIT_PREVIEW=false

